<resources>

    <style name="Base.Theme.Dopamine" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/md_theme_light_primary</item>
        <item name="colorOnPrimary">@color/md_theme_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/md_theme_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/md_theme_light_onPrimaryContainer</item>
        <item name="colorSecondary">@color/md_theme_light_secondary</item>
        <item name="colorOnSecondary">@color/md_theme_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/md_theme_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/md_theme_light_onSecondaryContainer</item>
        <item name="colorTertiary">@color/md_theme_light_tertiary</item>
        <item name="colorOnTertiary">@color/md_theme_light_onTertiary</item>
        <item name="colorTertiaryContainer">@color/md_theme_light_tertiaryContainer</item>
        <item name="colorOnTertiaryContainer">@color/md_theme_light_onTertiaryContainer</item>
        <item name="colorError">@color/md_theme_light_error</item>
        <item name="colorErrorContainer">@color/md_theme_light_errorContainer</item>
        <item name="colorOnError">@color/md_theme_light_onError</item>
        <item name="colorOnErrorContainer">@color/md_theme_light_onErrorContainer</item>
        <item name="android:colorBackground">@color/md_theme_light_background</item>
        <item name="colorOnBackground">@color/md_theme_light_onBackground</item>
        <item name="colorSurface">@color/md_theme_light_surface</item>
        <item name="colorOnSurface">@color/md_theme_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/md_theme_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/md_theme_light_onSurfaceVariant</item>
        <item name="colorOutline">@color/md_theme_light_outline</item>
        <item name="colorOnSurfaceInverse">@color/md_theme_light_inverseOnSurface</item>
        <item name="colorSurfaceInverse">@color/md_theme_light_inverseSurface</item>
        <item name="colorPrimaryInverse">@color/md_theme_light_inversePrimary</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowActivityTransitions">true</item>

        <!-- Typography Overhaul -->
        <item name="textAppearanceDisplayLarge">@style/TextAppearance.Dopamine.DisplayLarge</item>
        <item name="textAppearanceDisplayMedium">@style/TextAppearance.Dopamine.DisplayMedium</item>
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.Dopamine.DisplaySmall</item>
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.Dopamine.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Dopamine.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Dopamine.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Dopamine.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Dopamine.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Dopamine.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Dopamine.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Dopamine.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Dopamine.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Dopamine.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Dopamine.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Dopamine.LabelSmall</item>
    </style>

    <!-- Gotham for large punchy text -->
    <style name="TextAppearance.Dopamine.DisplayLarge" parent="TextAppearance.Material3.DisplayLarge">
        <item name="fontFamily">@font/gotham</item>
    </style>
    <style name="TextAppearance.Dopamine.DisplayMedium" parent="TextAppearance.Material3.DisplayMedium">
        <item name="fontFamily">@font/gotham</item>
    </style>
    <style name="TextAppearance.Dopamine.DisplaySmall" parent="TextAppearance.Material3.DisplaySmall">
        <item name="fontFamily">@font/gotham</item>
    </style>
    <style name="TextAppearance.Dopamine.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="fontFamily">@font/gotham</item>
    </style>
    <style name="TextAppearance.Dopamine.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="fontFamily">@font/gotham</item>
    </style>
    <style name="TextAppearance.Dopamine.HeadlineSmall" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="fontFamily">@font/gotham</item>
    </style>

    <!-- Circular Spotify for Titles (e.g. app bars, prominent elements) -->
    <style name="TextAppearance.Dopamine.TitleLarge" parent="TextAppearance.Material3.TitleLarge">
        <item name="fontFamily">@font/circular_spotify</item>
    </style>
    <style name="TextAppearance.Dopamine.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="fontFamily">@font/circular_spotify</item>
    </style>
    <style name="TextAppearance.Dopamine.TitleSmall" parent="TextAppearance.Material3.TitleSmall">
        <item name="fontFamily">@font/circular_spotify</item>
    </style>

    <!-- Proxima Nova for highly readable body text -->
    <style name="TextAppearance.Dopamine.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="fontFamily">@font/proxima_nova</item>
    </style>
    <style name="TextAppearance.Dopamine.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="fontFamily">@font/proxima_nova</item>
    </style>
    <style name="TextAppearance.Dopamine.BodySmall" parent="TextAppearance.Material3.BodySmall">
        <item name="fontFamily">@font/proxima_nova</item>
    </style>

    <!-- Circular Std for Labels (buttons, small indicators) -->
    <style name="TextAppearance.Dopamine.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="fontFamily">@font/circular_std</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="TextAppearance.Dopamine.LabelMedium" parent="TextAppearance.Material3.LabelMedium">
        <item name="fontFamily">@font/circular_std</item>
        <item name="android:textAllCaps">false</item>
    </style>
    <style name="TextAppearance.Dopamine.LabelSmall" parent="TextAppearance.Material3.LabelSmall">
        <item name="fontFamily">@font/circular_std</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="ToolbarTheme" parent="ThemeOverlay.AppCompat.Light">
        <item name="android:fontFamily">@font/circular_spotify</item>
        <item name="android:textSize">18sp</item>
    </style>

    <style name="Theme.Dopamine" parent="Base.Theme.Dopamine" />

    <style name="Widget.BottomNavigationView"
        parent="Widget.Design.BottomNavigationView">
        <item name="fontFamily">@font/circular_spotify</item>
    </style>

</resources>